@model GameMapStorageWebSite.Entities.GameMap

@{
    ViewData["Title"] = "Set Thumbnail";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.GameMapId">@Model.EnglishTitle</a></li>
        <li class="breadcrumb-item active" aria-current="page">Set Thumbnail</li>
    </ol>
</nav>

<h1>Set Thumbnail</h1>
<h4>@Model.EnglishTitle</h4>
<hr />

@if (ViewBag.ImageError != null)
{
    <div class="alert alert-danger">
        @ViewBag.ImageError
    </div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <h5>Current Thumbnail</h5>
        <img src="@ImagePathHelper.GetThumbnail(false, Model)" class="mw-100" />
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <h5>Upload from file</h5>
        <form asp-action="SetThumbnail" asp-route-id="@Model.GameMapId" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="GameMapId" />
            <div class="form-group">
                <label for="imageFile" class="control-label">Image file</label>
                <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Upload" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <h5>Import from URL</h5>
        <form asp-action="SetThumbnail" asp-route-id="@Model.GameMapId" method="post">
            <input type="hidden" asp-for="GameMapId" />
            <div class="form-group">
                <label for="imageUri" class="control-label">URL to map thumbnail</label>
                <input name="imageUri" id="imageUri" class="form-control" />
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Import" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Details" asp-route-id="@Model.GameMapId">Back to details</a>
</div>
